{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "default_agent": "plan",
  "provider": {
    "corp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Corp Gateway",
      "options": {
        "baseURL": "https://llm-gateway.company.internal/v1"
      },
      "models": {
        "ops-coder": {
          "name": "Ops Coder"
        }
      }
    }
  },
  "model": "corp/ops-coder",
  "small_model": "corp/ops-coder",
  "server": {
    "hostname": "127.0.0.1",
    "port": 4096,
    "cors": [
      "http://localhost:3000"
    ]
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "deny",
    "bash": {
      "*": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "grep *": "allow"
    },
    "webfetch": "deny",
    "skill": {
      "*": "deny",
      "incident-triage": "allow"
    }
  },
  "agent": {
    "plan": {
      "model": "corp/ops-coder",
      "permission": {
        "edit": "deny",
        "webfetch": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "grep *": "allow"
        },
        "skill": {
          "incident-triage": "allow"
        }
      }
    },
    "build": {
      "model": "corp/ops-coder",
      "permission": {
        "edit": "ask",
        "webfetch": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "grep *": "allow",
          "git push*": "deny"
        },
        "skill": {
          "incident-triage": "allow"
        }
      }
    }
  }
}
